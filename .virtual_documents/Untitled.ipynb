import pandas as pd
import numpy as np


df = pd.read_csv("powerplant_data.csv")


df.head()


# AT => temperature 
# V => Vaccum
# AP => Pressure
# RH => humidity

# PE => Produced energy


df.isnull().sum()


X = df.drop("PE", axis=1)
